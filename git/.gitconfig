[core]
    editor = "zed --wait"
    autocrlf = input          # consistent line endings
    excludesfile = ~/.gitignore_global
    safecrlf = true
    pager = less -FRSX

[init]
    defaultBranch = main

[merge]
    conflictstyle = zdiff3

[diff]
    colorMoved = default

[color]
    ui = auto

[alias]
    st = status
    co = checkout
    br = branch
    cm = commit
    df = diff
    gr = grep
    lg = log --graph --decorate --oneline --abbrev-commit
    amend = commit --amend --no-edit
    unstage = reset HEAD --
    last = log -1 HEAD

[push]
    default = simple
    autoSetupRemote = true

[pull]
    rebase = true

[fetch]
    prune = true

[include]
    path = ~/.gitconfig.local   # contains PID or sensitive info

[user]
    # leave empty here; filled in local config
